{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FocusPulse",
  "version": "1.0.0",
  "identifier": "com.focuspulse.tracker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "FocusPulse",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true,
        "visible": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "publisher": "FocusPulse",
    "copyright": "Copyright © 2026 FocusPulse",
    "category": "Utility",
    "shortDescription": "Screen Time & Focus Tracker for Windows",
    "longDescription": "FocusPulse monitors your application usage, tracks focus time, and helps you understand and improve your digital habits. Fully offline, no cloud, no telemetry."
  }
}